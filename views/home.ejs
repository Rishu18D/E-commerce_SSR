<!-- views/home.ejs -->
<%- include('partials/header') %>

<main class="container mx-auto mt-10 px-4">
    <!-- Buttons for adding product and profile -->
    <div class="mb-6 flex space-x-4">
        <% if (currentUser && currentUser.seller) { %>
            <a href="/products/add" class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded inline-block">Add Product</a>
        <% } %>
    </div>

    <h2 class="text-3xl font-bold mb-4">Welcome to Our E-Commerce Website</h2>
    <p class="text-lg mb-4">Explore our products, place orders</p>
    
    <!-- Product Listing -->
    <h2 class="text-xl font-semibold mt-10 mb-4">Products</h2>

    <% if (products && products.length === 0) { %>
        <p class="text-gray-700">No products available.</p>
    <% } else { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            <% products.forEach(product => { %>
                <div class="bg-white shadow-md rounded-lg overflow-hidden">
                    <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full h-64 object-cover">
                    <div class="p-4">
                        <h3 class="text-xl font-semibold mb-2"><%= product.name %></h3>
                        <p class="text-gray-700 mb-2">Price: $<%= product.price %></p>
                        <p class="text-gray-700 mb-4 truncate" title="<%= product.description %>"><%= product.description %></p>
                        
                        <!-- Form for adding product to cart -->
                        <form action="/users/cart/add/<%= product._id %>" method="POST" class="flex items-center mb-4">
                            <button type="submit" class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded inline-block">Add to Cart</button>
                        </form>
                        
                        <a href="/products/<%= product._id %>" class="bg-green-500 hover:bg-green-700 text-white font-bold py-2 px-4 rounded inline-block">Order Product</a>
                    </div>
                </div>
            <% }); %>
        </div>
    <% } %>
</main>

<%- include('partials/footer') %>
