<%- include('../partials/header') %>

<div class="container mx-auto mt-10 px-4">
    <div class="bg-white rounded-lg shadow-lg">
        <div class="flex flex-col lg:flex-row">
            <% if (product) { %>
                <!-- Product Image -->
                <div class="w-full lg:w-1/2 p-4">
                    <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full h-auto rounded-lg shadow-md">
                </div>

                <!-- Product Details -->
                <div class="w-full lg:w-1/2 p-4 flex flex-col justify-center">
                    <h2 class="text-3xl font-bold mb-4"><%= product.name %></h2>
                    <p class="text-xl mb-2"><strong>Price:</strong> $<%= product.price %></p>
                    <p class="text-gray-700 mb-6"><strong>Description:</strong> <%= product.description %></p>
                    <!-- Add more product details as needed -->
                    
                    <!-- Buy Product button -->
                    <form action="/orders/create" method="post" class="text-center">
                        <input type="hidden" name="productId" value="<%= product._id %>">
                        <button type="submit" class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded-lg focus:outline-none">Buy Product</button>
                    </form>
                </div>
            <% } else { %>
                <p>Product not found.</p>
            <% } %>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
