<!-- sales.ejs -->
<%- include('partials/header') %>

<main class="container mx-auto mt-10 px-4">
    <h2 class="text-3xl font-bold mb-6">Sales</h2>

    <% if (sales && sales.length === 0) { %>
        <p class="text-gray-700">No sales available at the moment.</p>
    <% } else { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            <% sales.forEach(sale => { %>
                <div class="bg-white shadow-md rounded-lg overflow-hidden">
                    <img src="<%= sale.image %>" alt="<%= sale.name %>" class="w-full h-64 object-cover">
                    <div class="p-4">
                        <h3 class="text-xl font-semibold mb-2"><%= sale.name %></h3>
                        <p class="text-gray-700 mb-2">Original Price: $<%= sale.originalPrice.toFixed(2) %></p>
                        <p class="text-gray-700 mb-2">Sale Price: $<%= sale.salePrice.toFixed(2) %></p>
                        <p class="text-gray-700 mb-4 truncate" title="<%= sale.description %>"><%= sale.description %></p>
                        
                        <!-- Link to product details -->
                        <a href="/products/view?name=<%= encodeURIComponent(sale.name) %>" class="block bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded mt-2 text-center">View Product</a>
                    </div>
                </div>
            <% }); %>
        </div>
    <% } %>
</main>

<%- include('partials/footer') %>
